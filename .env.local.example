# MongoDB Atlas — cadena de conexión (admin: llx0FANGcXVC1bBB)
# Ejemplo: mongodb+srv://usuario:password@cluster0.abc123.mongodb.net/real-oviedo-news
MONGODB_URI=mongodb+srv://admin:llx0FANGcXVC1bBB@cluster0.XXXXX.mongodb.net/real-oviedo-news

# NextAuth — genera un secreto con: openssl rand -base64 32
NEXTAUTH_SECRET=CAMBIA_ESTO_POR_UN_STRING_SECRETO_LARGO_Y_ALEATORIO

# URL pública de tu app (en desarrollo: http://localhost:3000)
NEXTAUTH_URL=http://localhost:3000
